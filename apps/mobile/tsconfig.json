{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ES2020"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["react", "expo"],
    "paths": {
      "@/*": ["./src/*"],
      "@futureroots/types": ["../../packages/types/src/index.ts"],
      "@futureroots/api-client": ["../../packages/api-client/src/index.ts"],
      "@futureroots/tokens": ["../../packages/tokens/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
