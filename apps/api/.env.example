# Copy to .env and adjust. All settings are prefixed FUTUREROOTS_.
FUTUREROOTS_DATABASE_URL=postgresql+psycopg://futureroots:futureroots@localhost:5432/futureroots
FUTUREROOTS_JWT_SECRET=dev-secret-change-in-production
FUTUREROOTS_WEB_BASE_URL=http://localhost:3000

# FutureRoots Premium — Stripe Price ids (amounts live in Stripe, never in code).
# Leave empty on the local backend; in stripe mode empty ids keep Premium
# checkout dark (503) rather than broken.
FUTUREROOTS_STRIPE_PRICE_MONTHLY=
FUTUREROOTS_STRIPE_PRICE_ANNUAL=
FUTUREROOTS_STRIPE_PRICE_GIFT_YEAR=
